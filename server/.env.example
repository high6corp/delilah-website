# Server
NODE_ENV=development
PORT=3001

# Frontend origin for CORS (Vite default)
CLIENT_URL=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://delilah:delilah_password@localhost:5432/delilah_db?schema=public

# File storage (absolute path outside web root)
# On Windows use a Windows-style absolute path, e.g. C:\Workspace\Build\delilah-website\uploads
# Git Bash paths like /c/... will be interpreted as C:\c\... by Node.js.
# IMPORTANT: In production (Docker/Railway) this directory MUST be mounted to a persistent
# volume, otherwise uploads will be lost on every deploy/restart. Mount the same host path
# or Railway Volume at this location. See docker-compose.yml for an example.
UPLOAD_DIR=/var/lib/delilah/uploads

# Auth
JWT_SECRET=change_this_to_a_random_32_char_string_in_production
BCRYPT_ROUNDS=12

# Session lifetime. Examples: 15m, 1h, 24h, 7d, 30d.
# Remember-me sessions are used when the user checks "Remember this device" on login.
JWT_EXPIRES_IN=15m
JWT_REMEMBER_ME_EXPIRES_IN=30d

# Cookie max-age in milliseconds. Should match the JWT expiry above.
COOKIE_MAX_AGE_MS=900000
COOKIE_REMEMBER_ME_MAX_AGE_MS=2592000000

# Optional: bcrypt hash of the family password. If set, login compares against this
# instead of the SiteConfig table, which is ideal for Railway/serverless deployments.
# Generate with: node -e "console.log(require('bcrypt').hashSync('your-password', 12))"
PASSWORD_HASH=

# Family password used on first seed (bcrypt hash will be stored in DB)
# In production, generate the hash separately and set it directly, or keep this only for initial setup.
FAMILY_PASSWORD=delilah2025

# Cookie
COOKIE_NAME=delilah_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Upload limits (bytes)
MAX_PHOTO_SIZE=10485760
MAX_VIDEO_SIZE=104857600

# Optional: serve frontend static files from the backend (production)
# Path to the frontend build output. Can be relative to the server directory.
# Example: STATIC_FILES_DIR=../app/dist
STATIC_FILES_DIR=

# Contact form email via SMTP2GO REST API
# SMTP2GO_API_KEY=your-api-key
# SMTP2GO_SENDER=noreply@example.com
# CONTACT_RECIPIENT=miracle@example.com
